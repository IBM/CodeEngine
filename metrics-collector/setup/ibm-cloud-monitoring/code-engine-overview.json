{
  "name": "IBM Code Engine - Container Resource Overview",
  "description": "Overview of Code Engine container resource usage: CPU/memory current vs limits, with filtering by component_type and component_name",
  "public": false,
  "panels": [
    {
      "id": 1,
      "type": "text",
      "name": "Dashboard Overview",
      "description": "",
      "markdownSource": "## Code Engine Container Resources\n\nMonitor CPU, memory, and ephemeral storage usage across Code Engine containers.\n\n**Use the scope filters above to narrow by:**\n- `component_type` (app, job, function)\n- `component_name` (specific app/job name)\n- `namespace`\n- `pod_name`",
      "transparentBackground": false,
      "panelTitleVisible": true,
      "textAutosized": false
    },
    {
      "id": 2,
      "type": "advancedTimechart",
      "name": "CPU Usage vs Limit (per Pod)",
      "description": "Current CPU usage compared to configured limits",
      "advancedQueries": [
        {
          "query": "ibm_codeengine_instance_cpu_usage_millicores",
          "enabled": true,
          "displayInfo": {
            "displayName": "CPU Usage",
            "timeSeriesDisplayNameTemplate": "{{component_name}}/{{pod_name}} usage",
            "type": "lines"
          },
          "format": {
            "unit": "number",
            "inputFormat": "1",
            "displayFormat": "auto",
            "decimals": 0,
            "yAxis": "auto",
            "nullValueDisplayMode": "nullGap"
          }
        },
        {
          "query": "ibm_codeengine_instance_cpu_limit_millicores",
          "enabled": true,
          "displayInfo": {
            "displayName": "CPU Limit",
            "timeSeriesDisplayNameTemplate": "{{component_name}}/{{pod_name}} limit",
            "type": "lines"
          },
          "format": {
            "unit": "number",
            "inputFormat": "1",
            "displayFormat": "auto",
            "decimals": 0,
            "yAxis": "auto",
            "nullValueDisplayMode": "nullGap"
          }
        }
      ],
      "legendConfiguration": {
        "enabled": true,
        "position": "bottom",
        "layout": "table",
        "showCurrent": true
      },
      "axesConfiguration": {
        "bottom": {
          "enabled": true
        },
        "left": {
          "enabled": true,
          "displayName": null,
          "unit": "auto",
          "displayFormat": "auto",
          "decimals": null,
          "minValue": 0.0,
          "maxValue": null,
          "minInputFormat": "0-100",
          "maxInputFormat": "0-100",
          "scale": "linear"
        },
        "right": {
          "enabled": true,
          "displayName": null,
          "unit": "auto",
          "displayFormat": "auto",
          "decimals": null,
          "minValue": 0.0,
          "maxValue": null,
          "minInputFormat": "1",
          "maxInputFormat": "1",
          "scale": "linear"
        }
      }
